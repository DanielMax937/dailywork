# Telegram (required for `npm run worker`)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_ID=

# HTTP proxy for outbound Telegram API requests (optional)
# Both worker (Telegraf) and web server (standalone sender) respect this.
# HTTPS_PROXY=http://127.0.0.1:7890
# HTTP_PROXY=http://127.0.0.1:7890

# Optional defaults
# AUTOMATION_DEFAULT_TIMEOUT_SEC=3600
# AUTOMATION_LOG_MAX_CHARS=8192
